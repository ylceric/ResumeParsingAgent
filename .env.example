# Copy to .env and fill in values.

# Required for LLM parsing, JD extraction, matching, and embeddings
OPENAI_API_KEY=

# Optional model overrides
OPENAI_MODEL=gpt-5.4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# When OCR yields very little text on images, call vision-capable model
OPENAI_VISION_FALLBACK=true
